{
  "name": "hse-guardian",
  "version": "1.0.0",
  "description": "Professional high-integrity safety evidence collection and management system.",
  "main": "index.tsx",
  "scripts": {
    "start": "node server.js",
    "dev": "vite",
    "build": "vite build",
    "deploy": "npm run build",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint \"**/*.{ts,tsx,js,jsx}\" --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "git-sync": "echo \"No git-sync configured. Use git or configure a workflow for release automation.\""
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "@supabase/supabase-js": "^2.45.0",
    "axios": "^1.6.0",
    "express": "^4.18.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^8.0.0",
    "eslint-plugin-react": "^7.32.0",
    "eslint-plugin-react-hooks": "^4.0.0",
    "jsdom": "^22.0.0",
    "prettier": "^2.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
